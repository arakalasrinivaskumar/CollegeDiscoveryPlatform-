generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  savedColleges SavedCollege[]
  questions     Question[]
  answers       Answer[]
  reviews       Review[]
}

model College {
  id          String         @id @default(cuid())
  name        String
  location    String
  state       String
  fees        Int
  rating      Float
  image       String?
  overview    String
  placement   Float
  cutoff      Int
  examCategory String        // "JEE_MAIN" | "JEE_ADVANCED" | "NEET" | "BITSAT"
  nirf        Int?           // NIRF ranking
  avgPackage  Float?         // Average placement package in LPA
  established Int?           // Year established
  courses     Course[]
  savedBy     SavedCollege[]
  reviews     Review[]
}

model Course {
  id        String   @id @default(cuid())
  name      String
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id])
}

model SavedCollege {
  userId    String
  collegeId String
  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])

  @@id([userId, collegeId])
}

model Question {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  answers   Answer[]
  createdAt DateTime @default(now())
}

model Answer {
  id         String   @id @default(cuid())
  text       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  text      String
  rating    Int
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}
